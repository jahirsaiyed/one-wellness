{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "regions": ["cdg1", "fra1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.gcc-wellness.com"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.tap.company; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://r2.gcc-wellness.com; connect-src 'self' https://api.gcc-wellness.com wss://api.gcc-wellness.com; frame-ancestors 'none';"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.gcc-wellness.com/v1/:path*" }
  ]
}
